generator client {
  provider = "prisma-client-js"
}

generator seed {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * Enums
 */
enum ClientType {
  FACTORY
  BANK
  INDIVIDUAL
  OTHER
}

enum UserRole {
  ADMIN
  COMMERCIAL
  MANAGER
  ACCOUNTANT
  GUARD
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  TIME_OFF
  JUSTIFIED_ABSENCE
  REPLACEMENT
  EXTRA_TIME
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum ContactType {
  EMAIL
  PHONE
  OTHER
}

enum PaymentStatus {
  DRAFT
  PENDING
  PAID
  CANCELLED
}

enum ReplacementType {
  PLANNED
  EMERGENCY
}

enum BillingStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum BillingLineType {
  SERVICE
  PERSONNEL
  MISSION
  CUSTOM
}

enum RateSource {
  MANUAL
  API
}

/**
 * Contract lifecycle states for review/confirmation
 */
enum ContractStatus {
  DRAFT
  SUBMITTED_FOR_REVIEW
  CONFIRMED
  REJECTED
}

/**
 * Core models
 */

model Company {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  address      String?
  baseCurrency String           @default("USD") // 3-letter ISO code
  contacts     CompanyContact[]
  users        User[]
  clients      Client[]
  personnel    Personnel[] // personnel for this company
  services     Service[] // services offered by this company
  billings     Billing[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  isDeleted    Boolean          @default(false)
  deletedAt    DateTime?

  @@index([name])
}

model CompanyContact {
  id        Int         @id @default(autoincrement())
  type      ContactType
  value     String
  company   Company     @relation(fields: [companyId], references: [id])
  companyId Int
  isDeleted Boolean    @default(false)
  deletedAt DateTime?

  @@index([companyId])
}

/**
 * Clients (the customers of the company)
 */
model Client {
  id         Int              @id @default(autoincrement())
  name       String
  type       ClientType
  address    String?
  contacts   ClientContact[]
  tax_number String?
  rib        String?
  sites      Site[] // Client has many sites
  company    Company          @relation(fields: [companyId], references: [id])
  companyId  Int
  contracts  ClientContract[]
  billings   Billing[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  isDeleted  Boolean          @default(false)
  deletedAt  DateTime?

  @@index([companyId])
  @@index([name])
}

model Site {
  id                 Int                  @id @default(autoincrement())
  name               String? // site name (e.g., "Main Gate")
  road               String? // road / street
  postalCode         String? // optional postal code
  address            String // free-form address line
  latitude           Float? // optional geo coordinates
  longitude          Float?
  city               City?                 @relation(fields: [cityId], references: [id])
  cityId             Int?
  client             Client               @relation(fields: [clientId], references: [id])
  clientId           Int
  missions           Mission[] // Site has many missions
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  isDeleted          Boolean              @default(false)
  deletedAt          DateTime?
  ClientContractSite ClientContractSite[]

  @@index([clientId])
  @@index([cityId])
}

model City {
  id        Int       @id @default(autoincrement())
  name      String
  state     String?
  country   String    @default("Country Name")
  sites     Site[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([name, state, country])
  @@index([name])
  @@index([state])
  @@index([country])
}

model ClientContact {
  id       Int         @id @default(autoincrement())
  type     ContactType
  value    String
  client   Client      @relation(fields: [clientId], references: [id])
  clientId Int
  isDeleted Boolean    @default(false)
  deletedAt DateTime?
  @@index([clientId])
}

/**
 * Services (e.g., Guard Service, Cooking Service, Cleaning Service)
 */
model Service {
  id                        Int                         @id @default(autoincrement())
  company                   Company                     @relation(fields: [companyId], references: [id])
  companyId                 Int
  code                      String? // optional short code
  name                      String
  description               String?
  isActive                  Boolean                     @default(true)
  defaultBasePay            Decimal?                    @db.Decimal(16, 2)
  defaultExtraPay           Decimal?                    @db.Decimal(16, 2)
  defaultClientPrice        Decimal?                    @db.Decimal(18, 2)
  personnel                 Personnel[]
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @default(now())
  isDeleted                 Boolean                     @default(false)
  deletedAt                 DateTime?
  BillingLine               BillingLine[]
  MissionServiceRequirement MissionServiceRequirement[]
  ClientContractService     ClientContractService[]
  ClientContractSiteService ClientContractSiteService[]

  @@index([companyId])
  @@index([name])
}

/**
 * Personnel — generic workers assigned to services
 */
model Personnel {
  id             Int                 @id @default(autoincrement())
  company        Company             @relation(fields: [companyId], references: [id])
  companyId      Int
  firstName      String
  lastName       String
  identifier     String?             @unique // optional employee code
  email          String?             @unique
  phone          String?
  hireDate       DateTime            @default(now())
  baseSalary     Decimal             @db.Decimal(16, 2)
  service        Service?            @relation(fields: [serviceId], references: [id])
  serviceId      Int?
  contracts      PersonnelContract[]
  assignments    MissionAssignment[]
  attendances    Attendance[]
  paymentRecords PaymentRecord[]
  billingLines   BillingLine[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now())
  isDeleted      Boolean             @default(false)
  deletedAt      DateTime?

  chiefMissions Mission[] @relation("ServiceChief")

  @@index([companyId])
  @@index([email])
  @@index([serviceId])
}

/**
 * Personnel contracts
 */
model PersonnelContract {
  id             Int       @id @default(autoincrement())
  contractNumber String    @unique
  personnel      Personnel @relation(fields: [personnelId], references: [id])
  personnelId    Int
  startDate      DateTime
  endDate        DateTime
  file           File?     @relation(fields: [fileId], references: [id])
  fileId         Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  companyId      Int?
  @@index([personnelId])
  @@index([startDate, endDate])
}

/**
 * Client contracts and extensions (what the client signs with the company)
 */
model ClientContract {
  id             Int                     @id @default(autoincrement())
  contractNumber String                  @unique
  client         Client                  @relation(fields: [clientId], references: [id])
  clientId       Int
  startDate      DateTime
  endDate        DateTime
  file           File?                   @relation(fields: [fileId], references: [id])
  fileId         Int?
  serviceRates   ClientContractService[] // per-service pricing defaults for this contract
  sites          ClientContractSite[] // the contract's coverage per site
  extensions     ContractExtension[]
  missions       Mission[]
  bills          Billing[]
  billingLines   BillingLine[]
  companyId      Int
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @default(now())
  status         ContractStatus          @default(DRAFT)
  submittedBy    User?                   @relation("ContractSubmittedBy", fields: [submittedById], references: [id])
  submittedById  Int?
  submittedAt    DateTime?
  confirmedBy    User?                   @relation("ContractConfirmedBy", fields: [confirmedById], references: [id])
  confirmedById  Int?
  confirmedAt    DateTime?
  isDeleted      Boolean                 @default(false)
  deletedAt      DateTime?

  @@index([clientId])
  @@index([startDate, endDate])
  @@index([companyId])
}

/**
 * Per-contract, per-service rates
 */
model ClientContractService {
  id               Int            @id @default(autoincrement())
  clientContract   ClientContract @relation(fields: [clientContractId], references: [id])
  clientContractId Int
  service          Service        @relation(fields: [serviceId], references: [id])
  serviceId        Int

  basePay     Decimal  @db.Decimal(16, 2) // what personnel gets (base)
  extraPay    Decimal  @db.Decimal(16, 2) // extra when on mission (e.g., overtime)
  clientPrice Decimal  @db.Decimal(18, 2) // how much client is charged per personnel unit
  createdAt   DateTime @default(now())

  @@unique([clientContractId, serviceId])
  @@index([serviceId])
}

/**
 * Each contract can cover multiple client sites (sites); for each site we can set start/end and the planned services/quantities
 */
model ClientContractSite {
  id               Int            @id @default(autoincrement())
  clientContract   ClientContract @relation(fields: [clientContractId], references: [id])
  clientContractId Int
  site             Site           @relation(fields: [siteId], references: [id])
  siteId           Int
  startDate        DateTime
  endDate          DateTime
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now())
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?

  // per-site per-service planned counts & price overrides (optional)
  services ClientContractSiteService[]

  @@index([clientContractId])
  @@index([siteId])
}

/**
 * For each contract-site, how many of each service are required (and optional per-site override rates)
 */
model ClientContractSiteService {
  id             Int                @id @default(autoincrement())
  contractSite   ClientContractSite @relation(fields: [contractSiteId], references: [id])
  contractSiteId Int
  service        Service            @relation(fields: [serviceId], references: [id])
  serviceId      Int
  requiredCount  Int                @default(1)
  basePay        Decimal            @default(0) @db.Decimal(16, 2)
  extraPay       Decimal            @default(0) @db.Decimal(16, 2)
  clientPrice    Decimal            @default(0) @db.Decimal(18, 2)
  createdAt      DateTime           @default(now())

  @@unique([contractSiteId, serviceId])
  @@index([contractSiteId])
  @@index([serviceId])
}

/**
 * Contract extensions
 */
model ContractExtension {
  id               Int            @id @default(autoincrement())
  clientContract   ClientContract @relation(fields: [clientContractId], references: [id])
  clientContractId Int
  startDate        DateTime
  endDate          DateTime
  file             File?          @relation(fields: [fileId], references: [id])
  fileId           Int?
  createdAt        DateTime       @default(now())

  @@index([clientContractId])
}

/**
 * Missions: one mission per site/time interval, may include multiple services/personnel types
 */
model Mission {
  id                  Int                         @id @default(autoincrement())
  contract            ClientContract              @relation(fields: [contractId], references: [id])
  contractId          Int
  site                Site?                       @relation(fields: [siteId], references: [id])
  siteId              Int?
  startDate           DateTime
  endDate             DateTime
  requiredPersonnel   Int // total personnel required (sum across services)
  extraPersonnelSlots Int                         @default(0)
  serviceChief        Personnel?                  @relation("ServiceChief", fields: [serviceChiefId], references: [id])
  serviceChiefId      Int?
  manager             User                        @relation("ManagedMissions", fields: [managerId], references: [id])
  managerId           Int
  assignments         MissionAssignment[]
  requirements        MissionServiceRequirement[]
  companyId           Int // denormalized owner ref
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @default(now())
  isDeleted           Boolean                     @default(false)
  deletedAt           DateTime?
  billingLines        BillingLine[] // reverse relation for BillingLine.mission
  paymentRecords      PaymentRecord[] // reverse relation for PaymentRecord.mission

  @@index([contractId])
  @@index([startDate, endDate])
  @@index([managerId])
  @@index([companyId])
}

/**
 * Requirements per mission: how many personnel by service and the exact rates used for billing/payment
 */
model MissionServiceRequirement {
  id            Int     @id @default(autoincrement())
  mission       Mission @relation(fields: [missionId], references: [id])
  missionId     Int
  service       Service @relation(fields: [serviceId], references: [id])
  serviceId     Int
  requiredCount Int     @default(1)
  basePay       Decimal @default(0) @db.Decimal(16, 2) // what personnel gets (base)
  extraPay      Decimal @default(0) @db.Decimal(16, 2) // extra when on mission (e.g., overtime)
  clientPrice   Decimal @default(0) @db.Decimal(18, 2) // how much client is charged per personnel unit
  billingLines  BillingLine[] 

  @@index([missionId])
  @@index([serviceId])
}

/**
 * Assigning personnel to posts in mission
 */
model MissionAssignment {
  id            Int          @id @default(autoincrement())
  mission       Mission      @relation(fields: [missionId], references: [id])
  missionId     Int
  personnel     Personnel    @relation(fields: [personnelId], references: [id])
  personnelId   Int
  post          String? // Post1, Post2, etc.
  role          String? // e.g., replacement, extra, regular
  isReplacement Boolean      @default(false)
  attendances   Attendance[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now())

  billingLines   BillingLine[]
  paymentRecords PaymentRecord[]

  @@index([missionId])
  @@index([personnelId])
}

/**
 * Attendance per assignment per day (or shift)
 */
model Attendance {
  id               Int               @id @default(autoincrement())
  assignment       MissionAssignment @relation(fields: [assignmentId], references: [id])
  assignmentId     Int
  date             DateTime
  status           AttendanceStatus
  checkIn          DateTime?
  checkOut         DateTime?
  replacementFor   Attendance?       @relation("ReplacementRecord", fields: [replacementForId], references: [id])
  replacementForId Int?
  replacements     Attendance[]      @relation("ReplacementRecord")
  replacementType  ReplacementType?
  notedBy          User?             @relation(fields: [notedById], references: [id])
  notedById        Int?
  personnel        Personnel?        @relation(fields: [personnelId], references: [id])
  personnelId      Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now())

  @@index([assignmentId, date])
  @@index([notedById])
  @@index([status])
}

/**
 * Users (system users)
 */
model User {
  id                      Int             @id @default(autoincrement())
  company                 Company         @relation(fields: [companyId], references: [id])
  companyId               Int
  identifier              String          @unique
  email                   String?
  password                String
  displayname             String?
  role                    UserRole
  managedMissions         Mission[]       @relation("ManagedMissions")
  attendances             Attendance[]
  notifications           Notification[]
  audits                  AuditLog[]
  paymentRecordsGenerated PaymentRecord[] @relation("PaymentRecordGeneratedBy")
  generatedBillings       Billing[]       @relation("BillingGeneratedBy")
  filesUploaded           File[]
  isDeleted               Boolean         @default(false)
  deletedAt               DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @default(now())

  // token version for immediate JWT invalidation
  tokenVersion Int @default(0)

  // permissions granted to the user
  userPermissions UserPermission[]

  // explicit back-relations for contracts workflow
  submittedContracts ClientContract[] @relation("ContractSubmittedBy")
  confirmedContracts ClientContract[] @relation("ContractConfirmedBy")
  UserPermission     UserPermission[] @relation("PermissionGrantedBy")

  @@index([companyId])
  @@index([role])
}

/**
 * Permissions
 */
model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // e.g. "personnel.manage", "attendance.edit"
  description String?
  group       String? // optional group name
  createdAt   DateTime @default(now())

  roleMappings RolePermission[]
  userMappings UserPermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleName     String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId Int
  createdAt    DateTime   @default(now())

  @@unique([roleName, permissionId])
  @@index([roleName])
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  user         User       @relation(fields: [userId], references: [id])
  userId       Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId Int
  grantedBy    User?      @relation("PermissionGrantedBy", fields: [grantedById], references: [id])
  grantedById  Int?
  grantedAt    DateTime   @default(now())
  revokedAt    DateTime?

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

/**
 * Notifications
 */
model Notification {
  id        Int                 @id @default(autoincrement())
  user      User                @relation(fields: [userId], references: [id])
  userId    Int
  message   String
  channel   NotificationChannel
  metadata  Json?
  read      Boolean             @default(false)
  createdAt DateTime            @default(now())
  isDeleted Boolean             @default(false)
  deletedAt DateTime?

  @@index([userId])
  @@index([channel])
}

/**
 * Audit logs
 */
model AuditLog {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  action       String // CREATE, UPDATE, DELETE, etc
  entity       String // model name
  entityId     Int
  timestamp    DateTime @default(now())
  previousData Json?
  newData      Json?

  @@index([userId])
  @@index([entity, entityId])
}

/**
 * Payments / payroll records (per personnel per period/assignment)
 */
model PaymentRecord {
  id            Int                @id @default(autoincrement())
  personnel     Personnel          @relation(fields: [personnelId], references: [id])
  personnelId   Int
  mission       Mission?           @relation(fields: [missionId], references: [id])
  missionId     Int?
  assignment    MissionAssignment? @relation(fields: [assignmentId], references: [id])
  assignmentId  Int?
  periodStart   DateTime
  periodEnd     DateTime
  basePay       Decimal            @db.Decimal(16, 2)
  extraPay      Decimal            @db.Decimal(16, 2)
  overtimePay   Decimal            @db.Decimal(16, 2)
  deductions    Decimal            @db.Decimal(16, 2)
  totalPay      Decimal            @db.Decimal(18, 2)
  status        PaymentStatus      @default(DRAFT)
  computedAt    DateTime?
  generatedBy   User?              @relation("PaymentRecordGeneratedBy", fields: [generatedById], references: [id])
  generatedById Int?
  details       Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @default(now())

  @@index([personnelId])
  @@index([missionId])
  @@index([periodStart, periodEnd])
}

/**
 * File metadata
 */
model File {
  id           Int      @id @default(autoincrement())
  url          String
  filename     String
  mimeType     String
  size         Int?
  checksum     String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  uploadedById Int?
  provider     String? // s3, gcs, local, etc.
  createdAt    DateTime @default(now())

  personnelContracts PersonnelContract[]
  clientContracts    ClientContract[]
  contractExtensions ContractExtension[]

  @@index([filename])
}

/**
 * ---- Billing / Invoice system ----
 */
model Billing {
  id                   Int             @id @default(autoincrement())
  invoiceNumber        String?
  company              Company         @relation(fields: [companyId], references: [id])
  companyId            Int
  client               Client          @relation(fields: [clientId], references: [id])
  clientId             Int
  contract             ClientContract? @relation(fields: [contractId], references: [id])
  contractId           Int?
  generatedBy          User?           @relation("BillingGeneratedBy", fields: [generatedById], references: [id])
  generatedById        Int?
  periodStart          DateTime
  periodEnd            DateTime
  invoiceDate          DateTime        @default(now())
  dueDate              DateTime?
  amountBaseCurrency   Decimal?         @db.Decimal(18, 2)
  isDeleted            Boolean          @default(false)
  deletedAt            DateTime?
  targetCurrency       String?
  conversionRate       Decimal?        @db.Decimal(24, 12)
  rateSource           RateSource?
  amountTargetCurrency Decimal?        @db.Decimal(18, 2)
  status               BillingStatus   @default(DRAFT)
  taxTotalBase         Decimal?        @db.Decimal(16, 2)
  taxTotalTarget       Decimal?        @db.Decimal(16, 2)
  notes                String?
  lines                BillingLine[]
  payments             Payment[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @default(now())

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([clientId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model BillingLine {
  id                  Int                @id @default(autoincrement())
  billing             Billing            @relation(fields: [billingId], references: [id])
  billingId           Int
  lineType            BillingLineType    @default(CUSTOM)
  description         String
  mission             Mission?           @relation(fields: [missionId], references: [id])
  missionId           Int?
  assignment          MissionAssignment? @relation(fields: [assignmentId], references: [id])
  assignmentId        Int?
  missionService      MissionServiceRequirement ?@relation(fields: [missionServiceId], references: [id]) 
  missionServiceId    Int?
  personnel           Personnel?         @relation(fields: [personnelId], references: [id])
  personnelId         Int?
  service             Service?           @relation(fields: [serviceId], references: [id])
  serviceId           Int?
  contract            ClientContract?    @relation(fields: [contractId], references: [id])
  contractId          Int?
  
  personnelCount         Int      @default(1)
  quantity               Int      @default(1)
  unitPriceBase          Decimal  @db.Decimal(18, 2)
  lineTotalBase          Decimal  @db.Decimal(20, 2)
  discountPercent        Decimal? @db.Decimal(5, 2)
  discountAmountBase     Decimal? @db.Decimal(18, 2)
  totalAfterDiscountBase Decimal  @db.Decimal(20, 2)

  taxPercent    Decimal? @db.Decimal(6, 2)
  taxAmountBase Decimal? @db.Decimal(18, 2)

  unitPriceTarget          Decimal? @db.Decimal(18, 2)
  lineTotalTarget          Decimal? @db.Decimal(20, 2)
  discountAmountTarget     Decimal? @db.Decimal(18, 2)
  totalAfterDiscountTarget Decimal? @db.Decimal(20, 2)
  taxAmountTarget          Decimal? @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([billingId])
  @@index([missionId])
  @@index([assignmentId])
  @@index([personnelId])
  @@index([contractId])
  @@index([serviceId])
}

model Payment {
  id        Int      @id @default(autoincrement())
  billing   Billing  @relation(fields: [billingId], references: [id])
  billingId Int
  amount    Decimal  @db.Decimal(18, 2)
  currency  String // ISO code
  paidAt    DateTime @default(now())
  method    String? // e.g., bank transfer, card
  reference String? // transaction reference
  notes     String?
  createdAt DateTime @default(now())

  @@index([billingId])
}
