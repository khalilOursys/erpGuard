generator client {
  provider = "prisma-client-js"
}

generator seed {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// *
///  * Core models
model Company {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  address          String?
  baseCurrency     String           @default("USD")
  rib              String?
  matriculeFiscale String?
  email            String?
  phone            String?
  logoId           Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  isDeleted        Boolean          @default(false)
  deletedAt        DateTime?
  billings         Billing[]
  clients          Client[]
  logo             File?            @relation(fields: [logoId], references: [id])
  contacts         CompanyContact[]
  personnel        Personnel[]
  services         Service[]
  users            User[]

  @@index([name])
  @@index([matriculeFiscale])
  @@index([email])
}

model CompanyContact {
  id        Int         @id @default(autoincrement())
  type      ContactType
  value     String
  companyId Int
  isDeleted Boolean     @default(false)
  deletedAt DateTime?
  company   Company     @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

/// *
///  * Clients (the customers of the company)
model Client {
  id         Int              @id @default(autoincrement())
  name       String
  type       ClientType
  address    String?
  tax_number String?
  rib        String?
  companyId  Int
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  isDeleted  Boolean          @default(false)
  deletedAt  DateTime?
  billings   Billing[]
  company    Company          @relation(fields: [companyId], references: [id])
  contacts   ClientContact[]
  contracts  ClientContract[]
  sites      Site[]

  @@index([companyId])
  @@index([name])
}

model Site {
  id                 Int                  @id @default(autoincrement())
  name               String?
  road               String?
  postalCode         String?
  address            String
  countryCode        String?
  stateCode          String?
  clientId           Int
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  isDeleted          Boolean              @default(false)
  deletedAt          DateTime?
  ClientContractSite ClientContractSite[]
  client             Client               @relation(fields: [clientId], references: [id])
  City               City[]               @relation("CityToSite")

  @@index([clientId])
}

model City {
  id        Int       @id @default(autoincrement())
  name      String
  state     String?
  country   String    @default("Country Name")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  sites     Site[]    @relation("CityToSite")

  @@unique([name, state, country])
  @@index([name])
  @@index([state])
  @@index([country])
}

model ClientContact {
  id        Int         @id @default(autoincrement())
  type      ContactType
  value     String
  clientId  Int
  fileId    Int?
  isDeleted Boolean     @default(false)
  deletedAt DateTime?
  client    Client      @relation(fields: [clientId], references: [id])
  file      File?       @relation(fields: [fileId], references: [id])

  @@index([clientId])
}

/// *
///  * Services (e.g., Guard Service, Cooking Service, Cleaning Service)
model Service {
  id                        Int                         @id @default(autoincrement())
  companyId                 Int
  code                      String?
  name                      String
  description               String?
  isActive                  Boolean                     @default(true)
  defaultBasePay            Decimal?                    @db.Decimal(16, 2)
  defaultExtraPay           Decimal?                    @db.Decimal(16, 2)
  defaultClientPrice        Decimal?                    @db.Decimal(18, 2)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @default(now())
  isDeleted                 Boolean                     @default(false)
  deletedAt                 DateTime?
  BillingLine               BillingLine[]
  ClientContractSiteService ClientContractSiteService[]
  personnel                 Personnel[]
  company                   Company                     @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([name])
}

/// *
///  * Personnel — generic workers assigned to services
model Personnel {
  id             Int                 @id @default(autoincrement())
  companyId      Int
  firstName      String
  lastName       String
  identifier     String?
  identifierType IdentifierType?
  email          String?             @unique
  phone          String?
  idPictureId    Int?                @unique
  hireDate       DateTime?
  baseSalary     Decimal             @db.Decimal(10, 2)
  serviceId      Int?
  fileId         Int?                @unique
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  isDeleted      Boolean             @default(false)
  deletedAt      DateTime?
  Assignment     Assignment[]
  BillingLine    BillingLine[]
  PaymentRecord  PaymentRecord[]
  company        Company             @relation(fields: [companyId], references: [id])
  file           File?               @relation("PersonnelFile", fields: [fileId], references: [id])
  idPicture      File?               @relation("PersonnelIdPicture", fields: [idPictureId], references: [id])
  service        Service?            @relation(fields: [serviceId], references: [id])
  contracts      PersonnelContract[]
  Attendance     Attendance[]        @relation("AttendanceToPersonnel")

  @@index([companyId])
  @@index([email])
  @@index([serviceId])
}

/// *
///  * Personnel contracts
model PersonnelContract {
  id             Int       @id @default(autoincrement())
  contractNumber String    @unique
  personnelId    Int
  startDate      DateTime
  endDate        DateTime
  fileId         Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?
  companyId      Int?
  file           File?     @relation(fields: [fileId], references: [id])
  personnel      Personnel @relation(fields: [personnelId], references: [id])

  @@index([personnelId])
  @@index([startDate, endDate])
}

/// *
///  * Client contracts and extensions (what the client signs with the company)
model ClientContract {
  id             Int                  @id @default(autoincrement())
  contractNumber String               @unique
  clientId       Int
  startDate      DateTime
  endDate        DateTime
  fileId         Int?
  companyId      Int
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now())
  status         ContractStatus       @default(DRAFT)
  submittedById  Int?
  submittedAt    DateTime?
  confirmedById  Int?
  confirmedAt    DateTime?
  isDeleted      Boolean              @default(false)
  deletedAt      DateTime?
  bills          Billing[]
  billingLines   BillingLine[]
  client         Client               @relation(fields: [clientId], references: [id])
  confirmedBy    User?                @relation("ContractConfirmedBy", fields: [confirmedById], references: [id])
  file           File?                @relation(fields: [fileId], references: [id])
  submittedBy    User?                @relation("ContractSubmittedBy", fields: [submittedById], references: [id])
  sites          ClientContractSite[]
  extensions     ContractExtension[]

  @@index([clientId])
  @@index([startDate, endDate])
  @@index([companyId])
}

/// *
///  * Each contract can cover multiple client sites (sites); for each site we can set start/end and the planned services/quantities
model ClientContractSite {
  id               Int                         @id @default(autoincrement())
  clientContractId Int
  siteId           Int
  startDate        DateTime
  endDate          DateTime
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @default(now())
  isDeleted        Boolean                     @default(false)
  deletedAt        DateTime?
  clientContract   ClientContract              @relation(fields: [clientContractId], references: [id])
  site             Site                        @relation(fields: [siteId], references: [id])
  services         ClientContractSiteService[]

  @@index([clientContractId])
  @@index([siteId])
}

/// *
///  * For each contract-site, how many of each service are required (and optional per-site override rates)
model ClientContractSiteService {
  id             Int                @id @default(autoincrement())
  contractSiteId Int
  serviceId      Int
  requiredCount  Int                @default(1)
  basePay        Decimal            @default(0) @db.Decimal(16, 2)
  extraPay       Decimal            @default(0) @db.Decimal(16, 2)
  clientPrice    Decimal            @default(0) @db.Decimal(18, 2)
  createdAt      DateTime           @default(now())
  assignments    Assignment[]
  contractSite   ClientContractSite @relation(fields: [contractSiteId], references: [id])
  service        Service            @relation(fields: [serviceId], references: [id])

  @@unique([contractSiteId, serviceId])
  @@index([contractSiteId])
  @@index([serviceId])
}

model Assignment {
  id                    Int                       @id @default(autoincrement())
  contractSiteServiceId Int
  postIndex             Int
  personnelId           Int?
  startDate             DateTime
  endDate               DateTime
  isReplacement         Boolean                   @default(false)
  replacementForId      Int?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  createdById           Int?
  contractSiteService   ClientContractSiteService @relation(fields: [contractSiteServiceId], references: [id])
  createdBy             User?                     @relation(fields: [createdById], references: [id])
  personnel             Personnel?                @relation(fields: [personnelId], references: [id])
  replacementFor        Assignment?               @relation("ReplacementAssignments", fields: [replacementForId], references: [id])
  replacements          Assignment[]              @relation("ReplacementAssignments")
  attendances           Attendance[]              @relation("AssignmentToAttendance")
}

/// *
///  * Contract extensions
model ContractExtension {
  id               Int            @id @default(autoincrement())
  clientContractId Int
  startDate        DateTime
  endDate          DateTime
  fileId           Int?
  createdAt        DateTime       @default(now())
  clientContract   ClientContract @relation(fields: [clientContractId], references: [id])
  file             File?          @relation(fields: [fileId], references: [id])

  @@index([clientContractId])
}

/// *
///  * Attendance per assignment per day (or shift)
model Attendance {
  id           Int              @id @default(autoincrement())
  assignmentId Int
  date         DateTime
  status       AttendanceStatus
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  notes        String?
  Assignment   Assignment[]     @relation("AssignmentToAttendance")
  Personnel    Personnel[]      @relation("AttendanceToPersonnel")
  User         User[]           @relation("AttendanceToUser")

  @@unique([assignmentId, date])
  @@index([assignmentId])
  @@index([date])
}

///  * Users (system users)
model User {
  id                      Int              @id @default(autoincrement())
  companyId               Int
  identifier              String           @unique
  email                   String?
  password                String
  displayname             String?
  role                    UserRole
  isDeleted               Boolean          @default(false)
  deletedAt               DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @default(now())
  tokenVersion            Int              @default(0)
  Assignment              Assignment[]
  audits                  AuditLog[]
  generatedBillings       Billing[]        @relation("BillingGeneratedBy")
  confirmedContracts      ClientContract[] @relation("ContractConfirmedBy")
  submittedContracts      ClientContract[] @relation("ContractSubmittedBy")
  filesUploaded           File[]
  notifications           Notification[]
  paymentRecordsGenerated PaymentRecord[]  @relation("PaymentRecordGeneratedBy")
  company                 Company          @relation(fields: [companyId], references: [id])
  UserPermission          UserPermission[] @relation("PermissionGrantedBy")
  userPermissions         UserPermission[]
  attendances             Attendance[]     @relation("AttendanceToUser")

  @@index([companyId])
  @@index([role])
}

/// *
///  * Permissions
model Permission {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  description  String?
  group        String?
  createdAt    DateTime         @default(now())
  roleMappings RolePermission[]
  userMappings UserPermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleName     String
  permissionId Int
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleName, permissionId])
  @@index([roleName])
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  userId       Int
  permissionId Int
  grantedById  Int?
  grantedAt    DateTime   @default(now())
  revokedAt    DateTime?
  grantedBy    User?      @relation("PermissionGrantedBy", fields: [grantedById], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

/// *
///  * Notifications
model Notification {
  id        Int                 @id @default(autoincrement())
  userId    Int
  message   String
  channel   NotificationChannel
  metadata  Json?
  read      Boolean             @default(false)
  createdAt DateTime            @default(now())
  isDeleted Boolean             @default(false)
  deletedAt DateTime?
  user      User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([channel])
}

/// *
///  * Audit logs
model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  action       String
  entity       String
  entityId     Int
  timestamp    DateTime @default(now())
  previousData Json?
  newData      Json?
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
}

/// *
///  * Payments / payroll records (per personnel per period/assignment)
model PaymentRecord {
  id            Int           @id @default(autoincrement())
  personnelId   Int
  assignmentId  Int?
  periodStart   DateTime
  periodEnd     DateTime
  basePay       Decimal       @db.Decimal(16, 2)
  extraPay      Decimal       @db.Decimal(16, 2)
  overtimePay   Decimal       @db.Decimal(16, 2)
  deductions    Decimal       @db.Decimal(16, 2)
  totalPay      Decimal       @db.Decimal(18, 2)
  status        PaymentStatus @default(DRAFT)
  computedAt    DateTime?
  generatedById Int?
  details       Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now())
  generatedBy   User?         @relation("PaymentRecordGeneratedBy", fields: [generatedById], references: [id])
  personnel     Personnel     @relation(fields: [personnelId], references: [id])

  @@index([personnelId])
  @@index([periodStart, periodEnd])
}

/// *
///  * File metadata
model File {
  id                 Int                 @id @default(autoincrement())
  filename           String
  url                String
  mimeType           String?
  size               Int?
  uploadedById       Int?
  provider           String?
  createdAt          DateTime            @default(now())
  ClientContact      ClientContact[]
  clientContracts    ClientContract[]
  companies          Company[]
  contractExtensions ContractExtension[]
  uploadedBy         User?               @relation(fields: [uploadedById], references: [id])
  personnel          Personnel?          @relation("PersonnelFile")
  Personnel          Personnel?          @relation("PersonnelIdPicture")
  personnelContracts PersonnelContract[]

  @@index([filename])
}

/// *
///  * Column configuration for billing/invoice display
model ColumnConfig {
  id        Int      @id @default(autoincrement())
  billingId Int
  key       String
  label     String
  visible   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  billing   Billing  @relation(fields: [billingId], references: [id], onDelete: Cascade)

  @@unique([billingId, key])
  @@index([billingId])
}

/// *
///  * ---- Billing / Invoice system ----
model Billing {
  id                   Int             @id @default(autoincrement())
  invoiceNumber        String?
  companyId            Int
  clientId             Int
  contractId           Int?
  generatedById        Int?
  periodStart          DateTime
  periodEnd            DateTime
  invoiceDate          DateTime        @default(now())
  dueDate              DateTime?
  amountBaseCurrency   Decimal?        @db.Decimal(18, 2)
  isDeleted            Boolean         @default(false)
  deletedAt            DateTime?
  targetCurrency       String?
  conversionRate       Decimal?        @db.Decimal(24, 12)
  rateSource           RateSource?
  amountTargetCurrency Decimal?        @db.Decimal(18, 2)
  status               BillingStatus   @default(DRAFT)
  taxTotalBase         Decimal?        @db.Decimal(16, 2)
  taxTotalTarget       Decimal?        @db.Decimal(16, 2)
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @default(now())
  client               Client          @relation(fields: [clientId], references: [id])
  company              Company         @relation(fields: [companyId], references: [id])
  contract             ClientContract? @relation(fields: [contractId], references: [id])
  generatedBy          User?           @relation("BillingGeneratedBy", fields: [generatedById], references: [id])
  lines                BillingLine[]
  columnConfigs        ColumnConfig[]
  payments             Payment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([clientId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model BillingLine {
  id                       Int             @id @default(autoincrement())
  billingId                Int
  lineType                 BillingLineType @default(CUSTOM)
  description              String
  missionServiceId         Int?
  personnelId              Int?
  serviceId                Int?
  contractId               Int?
  personnelCount           Int             @default(1)
  quantity                 Int             @default(1)
  unitPriceBase            Decimal         @db.Decimal(18, 2)
  lineTotalBase            Decimal         @db.Decimal(20, 2)
  discountPercent          Decimal?        @db.Decimal(5, 2)
  discountAmountBase       Decimal?        @db.Decimal(18, 2)
  totalAfterDiscountBase   Decimal         @db.Decimal(20, 2)
  taxPercent               Decimal?        @db.Decimal(6, 2)
  taxAmountBase            Decimal?        @db.Decimal(18, 2)
  unitPriceTarget          Decimal?        @db.Decimal(18, 2)
  lineTotalTarget          Decimal?        @db.Decimal(20, 2)
  discountAmountTarget     Decimal?        @db.Decimal(18, 2)
  totalAfterDiscountTarget Decimal?        @db.Decimal(20, 2)
  taxAmountTarget          Decimal?        @db.Decimal(18, 2)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @default(now())
  billing                  Billing         @relation(fields: [billingId], references: [id])
  contract                 ClientContract? @relation(fields: [contractId], references: [id])
  personnel                Personnel?      @relation(fields: [personnelId], references: [id])
  service                  Service?        @relation(fields: [serviceId], references: [id])

  @@index([billingId])
  @@index([personnelId])
  @@index([contractId])
  @@index([serviceId])
}

model Payment {
  id        Int      @id @default(autoincrement())
  billingId Int
  amount    Decimal  @db.Decimal(18, 2)
  currency  String
  paidAt    DateTime @default(now())
  method    String?
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  billing   Billing  @relation(fields: [billingId], references: [id])

  @@index([billingId])
}

/// *
///  * Enums
enum ClientType {
  FACTORY
  BANK
  INDIVIDUAL
  OTHER
}

enum UserRole {
  ADMIN
  COMMERCIAL
  MANAGER
  ACCOUNTANT
  GUARD
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  TIME_OFF
  JUSTIFIED_ABSENCE
  REPLACEMENT
  EXTRA_TIME
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum ContactType {
  EMAIL
  PHONE
  OTHER
}

enum PaymentStatus {
  DRAFT
  PENDING
  PAID
  CANCELLED
}

enum ReplacementType {
  PLANNED
  EMERGENCY
}

enum BillingStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum BillingLineType {
  SERVICE
  PERSONNEL
  MISSION
  CUSTOM
}

enum RateSource {
  MANUAL
  API
}

/// *
///  * Contract lifecycle states for review/confirmation
enum ContractStatus {
  DRAFT
  SUBMITTED_FOR_REVIEW
  CONFIRMED
  REJECTED
}

enum IdentifierType {
  NATIONAL_ID
  PASSPORT
  RESIDENCE_PERMIT
}
